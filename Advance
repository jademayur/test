Step 2 — Service (signals-based state, matching your FinVentory pattern)
typescript@Injectable({ providedIn: 'root' })
export class EmployeeService {
  private http = inject(HttpClient);
  private apiUrl = 'https://localhost:5001/api/employees';

  employees = signal<Employee[]>([]);
  totalCount = signal<number>(0);
  loading = signal<boolean>(false);

  loadAll(page = 1, pageSize = 10) {
    this.loading.set(true);
    this.http.get<ApiResponse<PagedResult<Employee>>>(`${this.apiUrl}?page=${page}&pageSize=${pageSize}`)
      .pipe(finalize(() => this.loading.set(false)))
      .subscribe({
        next: (res) => {
          this.employees.set(res.data.items);
          this.totalCount.set(res.data.totalCount);
        },
        error: (err) => console.error('Failed to load employees', err)
      });
  }

  create(employee: Employee): Observable<ApiResponse<Employee>> {
    return this.http.post<ApiResponse<Employee>>(this.apiUrl, employee);
  }

  update(id: number, employee: Employee): Observable<void> {
    return this.http.put<void>(`${this.apiUrl}/${id}`, employee);
  }

  delete(id: number): Observable<void> {
    return this.http.delete<void>(`${this.apiUrl}/${id}`);
  }
}
Step 3 — Standalone component with Reactive Forms
typescript@Component({
  selector: 'app-employee-list',
  standalone: true,
  imports: [CommonModule, ReactiveFormsModule],
  templateUrl: './employee-list.component.html'
})
export class EmployeeListComponent implements OnInit {
  private fb = inject(FormBuilder);
  employeeService = inject(EmployeeService);

  editingId = signal<number | null>(null);

  form = this.fb.group({
    name: ['', [Validators.required, Validators.maxLength(100)]],
    department: ['', Validators.required],
    salary: [0, [Validators.required, Validators.min(0)]]
  });

  ngOnInit() {
    this.employeeService.loadAll();
  }

  save() {
    if (this.form.invalid) {
      this.form.markAllAsTouched();
      return;
    }

    const value = this.form.getRawValue() as Employee;
    const id = this.editingId();

    const request$ = id
      ? this.employeeService.update(id, value)
      : this.employeeService.create(value);

    request$.subscribe({
      next: () => {
        this.resetForm();
        this.employeeService.loadAll();
      },
      error: (err) => console.error('Save failed', err)
    });
  }

  edit(emp: Employee) {
    this.editingId.set(emp.id!);
    this.form.patchValue(emp);
  }

  delete(id: number) {
    this.employeeService.delete(id).subscribe(() => this.employeeService.loadAll());
  }

  resetForm() {
    this.editingId.set(null);
    this.form.reset({ name: '', department: '', salary: 0 });
  }
}
