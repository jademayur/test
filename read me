export class EmployeeListComponent implements OnInit {
  employees: Employee[] = [];
  form: Employee = { name: '', department: '', salary: 0 };
  editingId: number | null = null;

  constructor(private employeeService: EmployeeService) {}

  ngOnInit() { this.loadEmployees(); }

  loadEmployees() {
    this.employeeService.getAll().subscribe(data => this.employees = data);
  }

  save() {
    if (this.editingId) {
      this.employeeService.update(this.editingId, this.form).subscribe(() => {
        this.editingId = null;
        this.resetForm();
        this.loadEmployees();
      });
    } else {
      this.employeeService.create(this.form).subscribe(() => {
        this.resetForm();
        this.loadEmployees();
      });
    }
  }

  edit(emp: Employee) {
    this.form = { ...emp };
    this.editingId = emp.id!;
  }

  delete(id: number) {
    this.employeeService.delete(id).subscribe(() => this.loadEmployees());
  }

  resetForm() {
    this.form = { name: '', department: '', salary: 0 };
  }
}

